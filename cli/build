#!/usr/bin/env bash
# Nest CLI surface — standard ./build interface.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")" && pwd)"

NEST_ROOT=""
dir="$APP_ROOT"
while [[ "$dir" != "/" ]]; do
  if [[ -f "$dir/scripts/nest-build/lib.sh" ]]; then
    NEST_ROOT="$dir"
    break
  fi
  dir="$(dirname "$dir")"
done
if [[ -z "$NEST_ROOT" && -f "$APP_ROOT/../nest/scripts/nest-build/lib.sh" ]]; then
  NEST_ROOT="$(cd "$APP_ROOT/../nest" && pwd)"
fi
if [[ -z "$NEST_ROOT" ]]; then
  echo "error: cannot find scripts/nest-build/lib.sh" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$NEST_ROOT/scripts/nest-build/lib.sh"

export NEST_BUILD_PROFILE=rust
export NEST_RUST_PACKAGE="finch-cli"
export NEST_RUST_BIN="finch-cli"

nest_build_main "$@"
